{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp: HH:mm:ss.ff}{Level:3}] {SourceContext: l} {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName"
    ]
  },
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Jwt": {
    "Issuer": "24eye.auth.tests",
    "Audience": "24eye.backend.tests",
    "SigningKey": "test-auth-service-signing-key-with-enough-length",
    "AccessTokenLifetimeMinutes": 15,
    "RefreshTokenLifetimeDays": 30
  },
  "OpenTelemetry": {
    "Enabled": false
  },
  "Email": {
    "Enabled": true,
    "SmtpHost": "localhost",
    "SmtpPort": 1025,
    "EnableSsl": false,
    "FromEmail": "no-reply@24eye.local",
    "FromName": "24Eye",
    "InviteBaseUrl": "http://localhost:3000/24eye/invite",
    "PasswordResetBaseUrl": "http://localhost:3000/24eye/reset-password"
  },
  "AllowedHosts": "*"
}
