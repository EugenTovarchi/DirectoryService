{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.AspNetCore.Hosting": "Information",
        "Microsoft.AspNetCore.Routing": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Error",
        "Microsoft.EntityFrameworkCore.Database.Transaction": "Error",
        "Microsoft.EntityFrameworkCore.Database.Connection": "Error",
        "Microsoft.EntityFrameworkCore.Update": "Error",
        "Microsoft.EntityFrameworkCore.Query": "Warning",
        "Microsoft.EntityFrameworkCore.Infrastructure": "Warning",
        "Microsoft.EntityFrameworkCore.Model": "Warning",
        "Microsoft.EntityFrameworkCore.Model.Validation": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Amazon": "Debug",
        "AWSSDK": "Debug",
        "System": "Warning",
        "System.Net.Http.HttpClient": "Information",
        "Hangfire": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp: HH:mm:ss.ff}{Level:3}] {SourceContext: l} {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://localhost:15341"
        }
      },
      {
        "Name": "Debug"
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName"
    ]
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5434;Database=file_service;Username=postgresUser;Password=postgresPassword",
    "Seq": "http://seq:5341",
    "Redis": "localhost:6379"
  },
  "Seq": {
    "ApiKey": ""
  },
  "CacheOptions": {
    "EnableCaching": true,
    "DefaultCacheDurationMinutes": 10,
    "DefaultLocalCacheDurationMinutes": 3,
    "VideoCacheDurationMinutes": 5
  },
  "S3Options":{
    "Endpoint": "https://s3.eu-central-003.backblazeb2.com",
    "AccessKey": "0037daf3a9c7c5a0000000001",
    "SecretKey": "K00343XNCnomgHzX/8JixfFeGWEvtzw",
    "WithSsl": true,
    "Region": "eu-central-003",
    "RequiredBuckets":  [
      "file-service-videos",
      "file-service-pictures",
      "file-service-documents",
