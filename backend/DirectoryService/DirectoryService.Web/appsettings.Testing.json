{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Wolverine": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss.ff} {Level:u3}] {SourceContext:l} {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [
      "FromLogContext"
    ]
  },
  "ConnectionStrings": {
    "DefaultConnection": "",
    "Redis": "localhost:6379",
    "RabbitMq": "amqp://localhost:5672"
  },
  "Messaging": {
    "UseExternalTransports": false
  },
  "OpenTelemetry": {
    "Enabled": false
  },
  "CacheOptions": {
    "EnableCaching": true,
    "DefaultCacheDurationMinutes": 10,
    "DefaultLocalCacheDurationMinutes": 3,
    "DepartmentsCacheDurationMinutes": 5
  },
  "FileServiceOptions": {
    "Url": "http://localhost:9003/",
    "TimeoutSeconds": 10
  },
  "AllowedHosts": "*"
}
